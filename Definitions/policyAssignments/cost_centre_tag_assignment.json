{
  "$schema": "https://raw.githubusercontent.com/Azure/enterprise-azure-policy-as-code/main/Schemas/policy-assignment-schema.json",
  "nodeName": "CostCenter-Tag-Assignment",
  "definitionEntry": {
    "policyName": "Require-CostCenter-Tag"
  },

  "assignment": {
    "name": "Demo-CostCenter-Tag",
    "displayName": "Demo - CostCenter Tag Enforcement",
    "description": "Applies the CostCenter tag governance rule to our enterprise scopes."
  },

  "children": [
    {
      "nodeName": "Dev/",
      "parameters": {
        "effect": "Audit"
      },
      "scope": {
        "dev": [
          "/providers/Microsoft.Management/managementGroups/EPAC-Dev"
        ]
      }
    },
    {
      "nodeName": "Prod/",
      "parameters": {
        "effect": "Deny"
      },
      "scope": {
        "prod": [
          "/providers/Microsoft.Management/managementGroups/Landing_Zone"
        ]
      }
    }
  ]
}