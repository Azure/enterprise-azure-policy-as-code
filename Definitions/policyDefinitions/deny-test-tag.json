{
  "name": "deny-test-tag",
  "properties": {
    "displayName": "Deny resources without test tag",
    "policyType": "Custom",
    "mode": "All",
    "description": "Test policy to deny resources without tag 'test'",
    "policyRule": {
      "if": {
        "field": "tags.test",
        "exists": "false"
      },
      "then": {
        "effect": "deny"
      }
    }
  }
}
